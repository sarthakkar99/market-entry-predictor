# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit your real keys.

# ── Required: OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini

# ── Required: Bright Data SERP ────────────────────────────────────
BRIGHTDATA_API_KEY=replace-me
BRIGHTDATA_ZONE=serp_api1

# ── Tunables ──────────────────────────────────────────────────────
# How many SERP results each agent fetches per query.
# Lower = faster + cheaper. 5 is a good demo default.
SERP_RESULTS=5

# Maximum tokens per LLM completion. Raise for richer outputs.
MAX_TOKENS=1500

# ── Runtime modes (default: false) ────────────────────────────────
# MOCK_MODE=true   →  scraper returns canned snippets (offline demo).
MOCK_MODE=false

# LLM_MOCK_MODE=true → bypass LLM for the 5 scout agents (legacy).
LLM_MOCK_MODE=false

# DEMO_MODE=true   →  enables a few demo niceties (legacy flag).
DEMO_MODE=false

# BAND_LOCAL_MODE=true → run band pub-sub locally without external broker.
BAND_LOCAL_MODE=false
